{
  "expo": {
    "name": "Apex Accounting",
    "slug": "apex-accounting",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "apex-accounting",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maverick500.apexaccounting",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Apex Accounting uses your camera to capture receipts for automatic data extraction.",
        "NSPhotoLibraryUsageDescription": "Apex Accounting accesses your photo library to import receipt images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.maverick500.apexaccounting",
      "versionCode": 1,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Apex Accounting uses your camera to capture receipts.",
          "photosPermission": "Apex Accounting accesses your photos to import receipts."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
